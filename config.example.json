{
  // mock: 오프라인 가상 종목/랜덤워크 (기본, 아무 준비 없이 바로 실행 가능)
  // sim : KIS 실계좌 앱키로 실시간 시세, 주문은 로컬 가상 체결 (모의투자 신청 불필요)
  // paper: KIS 모의투자 서버 (모의투자 신청 필요)
  // live: KIS 실서버, 진짜 돈. 충분히 검증 후에만 전환할 것
  "mode": "mock",

  // mock 모드 전용 -- 가상 종목 시작가
  "mock_start_price": 70000.0,
  // mock/sim 전용 가상 현금 시드값. paper/live는 실제 KIS 잔고를 조회하므로 무시됨
  "initial_cash": 10000000.0,

  // sim/paper/live에 필요한 KIS Developers 앱키/시크릿
  "appkey": "YOUR_APP_KEY",
  "appsecret": "YOUR_APP_SECRET",
  // paper/live 전용 계좌번호 (앞 8자리/뒤 2자리)
  "cano": "12345678",
  "acnt_prdt_cd": "01",

  // 매 스캔마다 볼 후보 종목 수 (거래량순위 기준)
  "watchlist_size": 5,
  // 그중 일봉 히스토리까지 정밀 분석할 상위 종목 수 (전일대비율 기준, watchlist_size 이하로)
  "deep_scan_limit": 5,

  // 동시 보유 가능한 최대 종목 수. 늘리면 분산되지만 poll 사이클마다 종목별 시세+뉴스
  // 조회가 추가돼 한 사이클이 길어짐
  "max_positions": 3,
  // 고정비율 리스크 모델 -- 이 트레이드가 stop_loss_pct에서 손절되면 총자산의 이
  // 비율만큼만 잃도록 매수 수량을 역산 (수량 = 총자산×이 비율 / (가격×stop_loss_pct)).
  // position_cash_fraction과 둘 중 더 작은 쪽으로 최종 수량이 결정됨
  "risk_per_trade_pct": 0.01,
  // 매수/추가매수 1회당 그 시점 매수가능금액 중 쓸 비율 (한 번에 계좌 전체를 한
  // 종목에 쏟아붓지 않도록, risk_per_trade_pct 기반 수량의 상한선 역할)
  "position_cash_fraction": 0.3,
  // 한 종목에 허용하는 최대 추가매수 횟수 (최초 매수는 제외)
  "max_topups_per_symbol": 3,
  // 한 종목의 총 투입액(원가 기준)이 전체 계좌 가치에서 차지할 수 있는 최대 비율
  "max_position_value_fraction": 0.5,
  // paper/live에서 주문 후 실제 체결(잔고 반영)을 확인하는 최대 대기 시간(초),
  // 2초 간격으로 폴링. 이 안에 안 채워지면 미체결로 보고 취소함
  "fill_confirm_timeout_seconds": 10,

  // SMA 골든/데드크로스에 쓰는 단기/장기 이동평균 기간(일)
  "sma_short": 5,
  "sma_long": 20,
  // 메인 루프 반복 주기(초) -- 실제 스캔은 이보다 훨씬 오래 걸릴 수 있음(레이트리밋 때문)
  "poll_seconds": 5,

  // 매매수수료 (매수/매도 양쪽) -- 실제 요율은 증권사/상품에 따라 다르니 확인 필요
  "fee_rate": 0.00015,
  // 증권거래세 (매도 시) -- 시장/시기에 따라 바뀌므로 확인 필요
  "tax_rate": 0.0018,
  // 수수료/세금 차감 후 이 이상 순손익률이면 익절 매도
  "take_profit_pct": 0.02,
  // 수수료/세금 차감 후 이 이상 손실이면 즉시 손절 매도
  "stop_loss_pct": 0.03,
  // 오늘 누적 실현손익이 총자산의 이 비율만큼 손실이면 그날은 신규 매수/추가매수/
  // 교체매도를 전부 중단 (보유 종목 모니터링/매도는 계속 -- 손절/익절은 안 막힘).
  // trades.log에서 오늘 날짜분을 합산해 복원되므로 재시작해도 한도 계산이 안 끊김
  "daily_loss_limit_pct": 0.05,
  // 위 일일 손실 한도 서킷브레이커 자체를 켤지 끌지 (false면 daily_loss_limit_pct 무시)
  "daily_loss_limit_enabled": true,

  // 스캔용 후보 스크리닝에 쓸 RSS 피드 URL 목록
  "news_feeds": [
    "https://www.mk.co.kr/rss/50200011/",
    "https://www.hankyung.com/feed/economy",
    "https://www.yna.co.kr/rss/economy.xml"
  ],

  // 네이버 뉴스검색 API (선택, developers.naver.com 무료 등록). 비워두면 시작 시 로그
  // 한 줄만 남기고 완전히 스킵 -- 보유 종목 모니터링의 종목별 뉴스 검색에만 쓰임
  // (Google 뉴스 검색과 나란히 병합), 스캔 전체 뉴스풀에는 아직 안 섞임
  "naver_client_id": "",
  "naver_client_secret": ""
}
